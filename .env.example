# ───────── Пример переменных окружения для Oops! ─────────
# Скопируйте в .env и при необходимости измените.
# .env в репозиторий НЕ коммитится (см. .gitignore).

# Часовой пояс контейнера
TZ=Europe/Moscow

# Secure-куки. Включайте (1) когда приложение работает за HTTPS (Caddy).
# Для локального HTTP оставьте пустым или 0.
COOKIE_SECURE=1

# Секретный ключ подписи сессий.
# Можно НЕ задавать — тогда сгенерируется автоматически и сохранится в data/secret.key.
# Если хотите задать вручную — впишите длинную случайную строку:
# SECRET_KEY=замените-на-длинную-случайную-строку
