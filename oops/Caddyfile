# Oops! — reverse-proxy с автоматическим HTTPS (Let's Encrypt).
#
# ВАРИАНТ 1 (по умолчанию): домен доступен из интернета, порты 80/443 проброшены.
# Caddy сам получит и будет продлевать бесплатный сертификат Let's Encrypt.
oops.example.com {
    reverse_proxy oops:8000
    encode gzip
}

# ─────────────────────────────────────────────────────────────────────────
# ВАРИАНТ 2: домен ТОЛЬКО внутри сети (резолвится на локальный IP, в интернет
# не смотрит). Let's Encrypt не сработает. Тогда закомментируйте блок выше и
# раскомментируйте этот — Caddy выдаст собственный самоподписанный сертификат
# (браузер будет предупреждать, пока не доверите его внутренний CA):
#
# oops.example.com {
#     reverse_proxy oops:8000
#     encode gzip
#     tls internal
# }
#
# ВАРИАНТ 3: внутренний домен + настоящий сертификат через DNS-проверку
# (без открытия портов наружу). Нужен плагин Caddy для вашего DNS-провайдера
# и API-токен. Напишите — соберём отдельный образ Caddy с нужным плагином.
